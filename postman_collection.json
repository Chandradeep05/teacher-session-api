            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/book",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            }
          }
