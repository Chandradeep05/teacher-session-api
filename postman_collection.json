          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/book",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"000000000000000000000000\"\n}"
            }
          }
        },
        {
          "name": "Book Session (Bad Session → 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/000000000000000000000000/book",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "6. Sessions — Complete",
      "item": [
        {
          "name": "Complete Session (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status is COMPLETED', () => pm.expect(res.data.status).to.eql('COMPLETED'));",
                  "pm.test('has completedAt', () => pm.expect(res.data.completedAt).to.not.be.null);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/complete"
          }
        },
        {
          "name": "Complete Session (Already Completed → 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/complete"
          }
        },
        {
          "name": "Complete Session (Bad Session → 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/sessions/000000000000000000000000/complete"
          }
        }
      ]
    },
    {
      "name": "7. User Session History (Aggregation)",
      "item": [
        {
          "name": "Get User Sessions (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('has upcoming array', () => pm.expect(res.data.upcoming).to.be.an('array'));",
                  "pm.test('has completed array', () => pm.expect(res.data.completed).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/sessions"
          }
        },
        {
          "name": "Get User Sessions (Bad User → 404)",
          "event": [
            {
              "listen": "test",
