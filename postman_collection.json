{
  "info": {
    "name": "Teacher-Session Booking API",
    "description": "Complete Postman collection for the Teacher-Session Booking API. Run requests in order for the full workflow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "teacherId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "sessionId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Teachers",
      "item": [
        {
          "name": "Create Teacher (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('success is true', () => pm.expect(res.success).to.be.true);",
                  "if (res.data && res.data._id) pm.collectionVariables.set('teacherId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/teachers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. Sarah Smith\",\n  \"email\": \"sarah.smith@example.com\",\n  \"specialization\": \"Mathematics\",\n  \"experience\": 10\n}"
            }
          }
        },
        {
          "name": "Create Teacher (Duplicate Email → 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/teachers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. Sarah Smith\",\n  \"email\": \"sarah.smith@example.com\",\n  \"specialization\": \"Mathematics\",\n  \"experience\": 10\n}"
            }
          }
        },
        {
          "name": "Create Teacher (Missing Fields → 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/teachers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. No Email\"\n}"
            }
          }
        }
      ]
    },
