                  "pm.test('success is true', () => pm.expect(res.success).to.be.true);",
                  "if (res.data && res.data._id) pm.collectionVariables.set('userId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"+1234567890\"\n}"
            }
          }
        },
        {
          "name": "Create User (Duplicate Email → 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"+1234567890\"\n}"
            }
          }
        },
        {
          "name": "Create User (Invalid Email → 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Bad Email User\",\n  \"email\": \"not-an-email\",\n  \"phone\": \"+1234567890\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Sessions — Create",
      "item": [
        {
          "name": "Create Session (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('status is AVAILABLE', () => pm.expect(res.data.status).to.eql('AVAILABLE'));",
                  "if (res.data && res.data._id) pm.collectionVariables.set('sessionId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"startTime\": \"2025-07-15T10:00:00.000Z\",\n  \"endTime\": \"2025-07-15T11:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "Create Session (Bad Teacher → 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacherId\": \"000000000000000000000000\",\n  \"startTime\": \"2025-07-15T10:00:00.000Z\",\n  \"endTime\": \"2025-07-15T11:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "Create Session (endTime ≤ startTime → 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"startTime\": \"2025-07-15T11:00:00.000Z\",\n  \"endTime\": \"2025-07-15T10:00:00.000Z\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Sessions — Available (Aggregation)",
      "item": [
        {
          "name": "Get Available Sessions (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('data is array', () => pm.expect(res.data).to.be.an('array'));",
                  "pm.test('has teacher populated', () => { if (res.data.length > 0) pm.expect(res.data[0].teacher).to.have.property('fullName'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sessions/available?dateTimestamp=1752570000000",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "available"],
              "query": [{ "key": "dateTimestamp", "value": "1752570000000" }]
            }
          }
        },
        {
          "name": "Get Available Sessions (Missing Timestamp → 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sessions/available"
          }
        }
      ]
    },
    {
      "name": "5. Sessions — Book",
      "item": [
        {
          "name": "Book Session (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status is BOOKED', () => pm.expect(res.data.status).to.eql('BOOKED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/book",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            }
          }
        },
        {
          "name": "Book Session (Already Booked → 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
