# ──────────────────────────────────────────────
# Teacher-Session Booking API — Environment
# ──────────────────────────────────────────────

PORT=3000

# MongoDB Atlas (recommended — matches production, works everywhere)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/teacher-session-db?retryWrites=true&w=majority

# MongoDB Local (fallback — for offline development)
# MONGODB_URI=mongodb://localhost:27017/teacher-session-db
